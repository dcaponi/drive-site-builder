{
	"version": 3,
	"routes": [
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^/?(?:/__data.json)?$",
			"dest": "/"
		},
		{
			"src": "^/api/apps/([^/]+?)/build/?(?:/__data.json)?$",
			"dest": "/api/apps/[appId]/build"
		},
		{
			"src": "^/api/apps/([^/]+?)/chat/?(?:/__data.json)?$",
			"dest": "/api/apps/[appId]/chat"
		},
		{
			"src": "^/api/apps/([^/]+?)/credentials/?(?:/__data.json)?$",
			"dest": "/api/apps/[appId]/credentials"
		},
		{
			"src": "^/api/apps/([^/]+?)/feedback/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/api/apps/[appId]/feedback/[feedbackId]"
		},
		{
			"src": "^/api/apps/([^/]+?)/token/?(?:/__data.json)?$",
			"dest": "/api/apps/[appId]/token"
		},
		{
			"src": "^/api/crud/([^/]+?)/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/api/crud/[appId]/[table]"
		},
		{
			"src": "^/api/crud/([^/]+?)/([^/]+?)/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/api/crud/[appId]/[table]/[id]"
		},
		{
			"src": "^/api/debug/?(?:/__data.json)?$",
			"dest": "/api/debug"
		},
		{
			"src": "^/app/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/app/[appId]"
		},
		{
			"src": "^/auth/callback/?(?:/__data.json)?$",
			"dest": "/auth/callback"
		},
		{
			"src": "^/auth/login/?(?:/__data.json)?$",
			"dest": "/auth/login"
		},
		{
			"src": "^/auth/logout/?(?:/__data.json)?$",
			"dest": "/auth/logout"
		},
		{
			"src": "^/dashboard/?(?:/__data.json)?$",
			"dest": "/dashboard"
		},
		{
			"src": "^/serve/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/serve/[appId]"
		},
		{
			"src": "^/serve/([^/]+?)/content/?(?:/__data.json)?$",
			"dest": "/serve/[appId]/content"
		},
		{
			"src": "^/view/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/view/[appId]"
		},
		{
			"src": "/.*",
			"dest": "/![-]/catchall"
		}
	],
	"overrides": {}
}