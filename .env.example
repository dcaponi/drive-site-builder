# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth 2.0 credentials
# Create at: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI: https://your-domain.com/auth/callback (and http://localhost:5173/auth/callback for dev)
GOOGLE_CLIENT_ID=123456789-abc.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Optional: restrict access to specific Google account emails (comma-separated)
# Leave empty to allow any Google account
ALLOWED_EMAILS=user1@gmail.com,user2@gmail.com
# Deprecated: single-email form still works for backwards compatibility
# ALLOWED_EMAIL=you@gmail.com

# Google Drive root folder ID (for the primary owner — first email in ALLOWED_EMAILS)
# Create a folder in your Google Drive and paste its ID here (from the URL)
# Other whitelisted users get auto-provisioned "drive-app-builder" folders in their own Drive
DRIVE_ROOT_FOLDER_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs

# JWT secret for signing session cookies (generate: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this

# App origin (used to build the OAuth callback URL)
# In development this is inferred automatically
# ORIGIN=https://your-vercel-app.vercel.app
